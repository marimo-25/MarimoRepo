@{
    Layout = null;
    var path   = Context.Request.Path.Value ?? "";
    var isDash = path == "/" || path.StartsWith("/Dashboard", StringComparison.OrdinalIgnoreCase);
    var isPay  = path.StartsWith("/Payments", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>家計ノート@(ViewBag.Title != null ? $" - {ViewBag.Title}" : "")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/antd@4.24.16/dist/antd.min.css" />
    <style>
        /* ── Base ── */
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f0f2f5;
            margin: 0;
        }

        /* ── Header ── */
        .app-header {
            background: #001529;
            display: flex;
            align-items: center;
            padding: 0 24px;
            height: 64px;
            position: sticky;
            top: 0;
            z-index: 200;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
        }
        .app-logo {
            color: #fff;
            font-size: 18px;
            font-weight: 700;
            margin-right: 40px;
            text-decoration: none;
            white-space: nowrap;
            letter-spacing: 0.02em;
            flex-shrink: 0;
        }
        .app-nav { flex: 1; display: flex; }
        .app-nav a {
            color: rgba(255,255,255,0.65);
            padding: 0 20px;
            height: 64px;
            line-height: 64px;
            display: inline-block;
            font-size: 14px;
            text-decoration: none;
            transition: color 0.2s, background 0.2s;
            border-bottom: 2px solid transparent;
        }
        .app-nav a:hover  { color: #fff; }
        .app-nav a.active { color: #fff; border-bottom-color: #1890ff; }
        .app-userinfo { display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
        .app-username { color: rgba(255,255,255,0.65); font-size: 13px; }

        /* ── Hamburger button (hidden on desktop) ── */
        .hamburger-btn {
            display: none;
            flex-direction: column;
            justify-content: center;
            gap: 5px;
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px 4px;
            margin-right: 12px;
        }
        .hamburger-line {
            display: block;
            width: 22px;
            height: 2px;
            background: rgba(255,255,255,0.85);
            border-radius: 1px;
            transition: transform 0.25s, opacity 0.25s;
        }
        /* X animation when open */
        .hamburger-btn.open .hamburger-line:nth-child(1) { transform: translateY(7px) rotate(45deg); }
        .hamburger-btn.open .hamburger-line:nth-child(2) { opacity: 0; }
        .hamburger-btn.open .hamburger-line:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

        /* ── Drawer overlay ── */
        .nav-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.45);
            z-index: 299;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s ease;
        }
        .nav-overlay.open { opacity: 1; pointer-events: all; }

        /* ── Drawer panel ── */
        .nav-drawer {
            position: fixed;
            top: 0;
            left: 0;
            height: 100%;
            width: 260px;
            background: #001529;
            z-index: 300;
            transform: translateX(-100%);
            transition: transform 0.25s ease;
            display: flex;
            flex-direction: column;
            box-shadow: 2px 0 12px rgba(0,0,0,0.35);
        }
        .nav-drawer.open { transform: translateX(0); }

        .nav-drawer-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 20px;
            height: 64px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
            flex-shrink: 0;
        }
        .nav-drawer-logo { color: #fff; font-size: 16px; font-weight: 700; }
        .nav-drawer-close {
            background: none;
            border: none;
            color: rgba(255,255,255,0.45);
            font-size: 18px;
            cursor: pointer;
            padding: 4px 6px;
            line-height: 1;
            transition: color 0.2s;
        }
        .nav-drawer-close:hover { color: #fff; }

        .nav-drawer-body { flex: 1; padding: 8px 0; overflow-y: auto; }
        .nav-drawer-item {
            display: block;
            padding: 14px 24px;
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-size: 14px;
            transition: background 0.15s, color 0.15s;
            border-left: 3px solid transparent;
        }
        .nav-drawer-item:hover  { background: rgba(255,255,255,0.05); color: #fff; }
        .nav-drawer-item.active { color: #1890ff; border-left-color: #1890ff; background: rgba(24,144,255,0.1); }

        .nav-drawer-footer {
            padding: 16px 20px;
            border-top: 1px solid rgba(255,255,255,0.08);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }
        .nav-drawer-username { color: rgba(255,255,255,0.45); font-size: 13px; }

        /* ── Page content ── */
        .app-page { padding: 24px; max-width: 1200px; margin: 0 auto; }

        /* ── antd plain-HTML tweaks ── */
        .ant-btn > span     { pointer-events: none; }
        .ant-table-cell     { vertical-align: middle !important; }
        .ant-form-item      { margin-bottom: 20px; }
        .ant-form-item-label { padding-bottom: 4px; }
        .ant-form-item-label label { font-weight: 500; color: rgba(0,0,0,0.85); }
        .page-header        { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; }
        .page-title         { font-size: 20px; font-weight: 600; color: rgba(0,0,0,0.85); margin: 0; }

        /* ── Mobile breakpoint ── */
        @@media (max-width: 768px) {
            .hamburger-btn  { display: flex; }
            .app-logo       { margin-right: 0; }
            .app-nav        { display: none; }
            .app-username   { display: none; }
            .app-userinfo .ant-btn { display: none; }
            .app-page       { padding: 16px; }
        }
    </style>
</head>
<body>

<!-- ── Overlay ── -->
<div class="nav-overlay" id="navOverlay"></div>

<!-- ── Drawer ── -->
<div class="nav-drawer" id="navDrawer" role="dialog" aria-label="ナビゲーション">
    <div class="nav-drawer-header">
        <span class="nav-drawer-logo">家計ノート</span>
        <button class="nav-drawer-close" id="drawerClose" aria-label="閉じる">&#x2715;</button>
    </div>
    <div class="nav-drawer-body">
        <a href="/Dashboard" class="nav-drawer-item @(isDash ? "active" : "")">ダッシュボード</a>
        <a href="/Payments"  class="nav-drawer-item @(isPay  ? "active" : "")">支払一覧</a>
    </div>
    <div class="nav-drawer-footer">
        <span class="nav-drawer-username">@Context.User.Identity?.Name</span>
        <form method="post" action="/account/logout" style="margin:0;">
            <button class="ant-btn ant-btn-sm"
                    style="color:rgba(255,255,255,0.65);border-color:rgba(255,255,255,0.3);background:transparent;">
                <span>ログアウト</span>
            </button>
        </form>
    </div>
</div>

<!-- ── Header ── -->
<header class="app-header">
    <button class="hamburger-btn" id="hamburgerBtn" aria-label="メニューを開く">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
    </button>
    <a href="/" class="app-logo">家計ノート</a>
    <nav class="app-nav">
        <a href="/Dashboard" class="@(isDash ? "active" : "")">ダッシュボード</a>
        <a href="/Payments"  class="@(isPay  ? "active" : "")">支払一覧</a>
    </nav>
    <div class="app-userinfo">
        <span class="app-username">@Context.User.Identity?.Name</span>
        <form method="post" action="/account/logout" style="margin:0;">
            <button class="ant-btn ant-btn-sm"
                    style="color:rgba(255,255,255,0.65);border-color:rgba(255,255,255,0.3);background:transparent;">
                <span>ログアウト</span>
            </button>
        </form>
    </div>
</header>

<!-- ── Page content ── -->
<main class="app-page">
    @RenderBody()
</main>

<script>
    (function () {
        const btn     = document.getElementById('hamburgerBtn');
        const drawer  = document.getElementById('navDrawer');
        const overlay = document.getElementById('navOverlay');
        const closeBtn = document.getElementById('drawerClose');

        function open() {
            drawer.classList.add('open');
            overlay.classList.add('open');
            btn.classList.add('open');
            btn.setAttribute('aria-label', 'メニューを閉じる');
            document.body.style.overflow = 'hidden';
        }
        function close() {
            drawer.classList.remove('open');
            overlay.classList.remove('open');
            btn.classList.remove('open');
            btn.setAttribute('aria-label', 'メニューを開く');
            document.body.style.overflow = '';
        }

        btn.addEventListener('click', function () {
            drawer.classList.contains('open') ? close() : open();
        });
        closeBtn.addEventListener('click', close);
        overlay.addEventListener('click', close);

        // Esc key to close
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') close();
        });
    })();
</script>

@RenderSection("Scripts", required: false)
</body>
</html>
