@model List<Household.Web.Common.Dtos.Payments.PaymentDto>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "支払一覧";
    var totalActive = Model.Where(p => p.Status != "Cancelled").Sum(p => p.Amount);
}

<div class="page-header">
    <h2 class="page-title">支払一覧</h2>
    <a href="/Payments/Create" class="ant-btn ant-btn-primary">
        <span>＋ 支払追加</span>
    </a>
</div>

@if (!Model.Any())
{
    <div class="ant-empty" style="padding: 48px 0; background:#fff; border-radius:8px; text-align:center;">
        <div class="ant-empty-description" style="color:rgba(0,0,0,0.25); font-size:14px;">支払データがありません</div>
    </div>
}
else
{
    <div class="ant-table-wrapper">
        <div class="ant-spin-nested-loading">
            <div class="ant-spin-container">
                <div class="ant-table ant-table-bordered" style="border-radius:8px;overflow:hidden;">
                    <div class="ant-table-container">
                        <div class="ant-table-content">
                            <table style="table-layout:auto;width:100%;">
                                <colgroup>
                                    <col style="width:120px;" />
                                    <col />
                                    <col style="width:130px;" />
                                    <col style="width:100px;" />
                                    <col style="width:100px;" />
                                    <col style="width:160px;" />
                                </colgroup>
                                <thead class="ant-table-thead">
                                    <tr>
                                        <th class="ant-table-cell">日付</th>
                                        <th class="ant-table-cell">店舗名</th>
                                        <th class="ant-table-cell" style="text-align:right;">金額</th>
                                        <th class="ant-table-cell">支払者</th>
                                        <th class="ant-table-cell" style="text-align:center;">ステータス</th>
                                        <th class="ant-table-cell" style="text-align:center;">操作</th>
                                    </tr>
                                </thead>
                                <tbody class="ant-table-tbody">
                                    @foreach (var p in Model)
                                    {
                                        <tr class="ant-table-row ant-table-row-level-0">
                                            <td class="ant-table-cell" style="color:rgba(0,0,0,0.45);font-size:13px;">
                                                @p.PaymentDate.ToString("yyyy/MM/dd")
                                            </td>
                                            <td class="ant-table-cell" style="font-weight:500;">
                                                @p.StoreName
                                            </td>
                                            <td class="ant-table-cell" style="text-align:right;font-variant-numeric:tabular-nums;font-weight:500;">
                                                ¥@p.Amount.ToString("N0")
                                            </td>
                                            <td class="ant-table-cell">@p.Payer</td>
                                            <td class="ant-table-cell" style="text-align:center;">
                                                @{
                                                    var (tagClass, tagLabel) = p.Status switch {
                                                        "Pending"   => ("ant-tag-processing", "未精算"),
                                                        "Settled"   => ("ant-tag-success",    "精算済"),
                                                        "Cancelled" => ("",                   "取消済"),
                                                        _           => ("",                    p.Status)
                                                    };
                                                }
                                                <span class="ant-tag @tagClass" style="margin:0;">@tagLabel</span>
                                            </td>
                                            <td class="ant-table-cell" style="text-align:center;">
                                                @if (p.Status == "Pending")
                                                {
                                                    <form method="post" action="/Payments/@p.Id/Settle"
                                                          style="display:inline-block;">
                                                        <button type="submit"
                                                                class="ant-btn ant-btn-primary ant-btn-sm">
                                                            <span>精算</span>
                                                        </button>
                                                    </form>
                                                    <form method="post" action="/Payments/@p.Id/Cancel"
                                                          style="display:inline-block;margin-left:8px;"
                                                          onsubmit="return confirm('取消しますか？')">
                                                        <input type="hidden" name="reason" value="手動取消" />
                                                        <button type="submit"
                                                                class="ant-btn ant-btn-sm ant-btn-dangerous">
                                                            <span>取消</span>
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <span style="color:rgba(0,0,0,0.25);">―</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr style="background:#fafafa;">
                                        <td class="ant-table-cell" colspan="2"
                                            style="font-weight:600;color:rgba(0,0,0,0.85);">合計（取消除く）</td>
                                        <td class="ant-table-cell"
                                            style="text-align:right;font-weight:700;font-size:15px;color:#1890ff;">
                                            ¥@totalActive.ToString("N0")
                                        </td>
                                        <td class="ant-table-cell" colspan="3"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
